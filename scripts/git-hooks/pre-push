#!/usr/bin/env bash
# Mirror of the GitHub Actions `check` job — runs locally before each push so
# we don't burn a CI run on a missed `ruff format` or a flaking test. Bypass
# in a pinch with `git push --no-verify`.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v uv >/dev/null 2>&1; then
    echo "pre-push: uv not found in PATH — skipping checks" >&2
    exit 0
fi

step() {
    printf '\n\033[1;34m== %s ==\033[0m\n' "$1"
}

step "ruff check"
uv run ruff check src/ tests/

step "ruff format --check"
uv run ruff format --check src/ tests/

step "pyright"
uv run pyright src/codexbot/

step "pytest"
uv run pytest --tb=short -q

echo
echo "pre-push: all checks green ✓"
