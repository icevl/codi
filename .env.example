# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated, required)
ALLOWED_USERS=123456789,987654321

# Tmux session name (optional, defaults to "codexbot")
TMUX_SESSION_NAME=codexbot

# Codex command to run in new windows (optional)
# Default: codex --no-alt-screen
CODEX_COMMAND=codex --no-alt-screen

# Codex sessions path for transcript scanning (optional)
# Default: ${CODEX_HOME:-~/.codex}/sessions
CODEXBOT_CODEX_SESSIONS_PATH=

# Monitor polling interval in seconds (optional, defaults to 2.0)
MONITOR_POLL_INTERVAL=2.0

# Max seconds to wait for a topic queue to drain before continuing user actions
CODEXBOT_QUEUE_DRAIN_TIMEOUT_SECONDS=5.0

# Number of parsed transcript histories to keep warm in memory for the web UI
CODEXBOT_HISTORY_CACHE_MAX_SESSIONS=8

# Show hidden directories in directory browser (optional)
CODEXBOT_SHOW_HIDDEN_DIRS=false

# Optional: tune window->session auto-detection retries
CODEXBOT_SESSION_DETECT_TIMEOUT=12.0
CODEXBOT_SESSION_DETECT_INTERVAL=1.5

# Optional: voice message transcription
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Web UI (optional). Set a password to enable the built-in web interface.
# Disabled when WEB_UI_PASSWORD is empty.
WEB_UI_PASSWORD=
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=8787
# Optional: pin the cookie signing key (otherwise persisted at ~/.codexbot/web_ui_secret)
WEB_UI_SECRET=

# Two-factor auth (Google Authenticator / TOTP). Default: required when the
# web UI is enabled. Set to false ONLY when fronted by another auth layer
# (VPN, mTLS, SSO). When required and no secret is configured, one is
# generated on first startup; check the logs for a QR + otpauth URI to scan
# once into your authenticator app. The secret persists at
# ~/.codexbot/web_ui_totp_secret. Delete that file to re-enroll.
WEB_UI_TOTP_REQUIRED=true
# Optional: pin the TOTP secret (base32). Useful for multi-host deployments
# that should share the same code.
WEB_UI_TOTP_SECRET=
# Labels shown inside the authenticator app entry.
WEB_UI_TOTP_ISSUER=CodexBot
WEB_UI_TOTP_ACCOUNT=

# Session cookie Secure attribute. "auto" (default) trusts the request scheme
# so plain-HTTP localhost still works; "true"/"false" force the value.
WEB_UI_COOKIE_SECURE=auto

# WebSocket Origin allowlist (comma-separated, full origins including
# scheme + port). Defaults to loopback variants of WEB_UI_HOST:WEB_UI_PORT.
# When fronting with a reverse proxy, set this to your public origin, e.g.
#   WEB_UI_ALLOWED_ORIGINS=https://codexbot.example.com
WEB_UI_ALLOWED_ORIGINS=
